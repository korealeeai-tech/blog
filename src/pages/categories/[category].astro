---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { BLOG_CATEGORIES, type BlogCategorySlug, getBlogCategory } from '../../categories';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	return BLOG_CATEGORIES.map((category) => ({
		params: { category: category.slug },
		props: { categorySlug: category.slug },
	}));
}

type Props = {
	categorySlug: BlogCategorySlug;
};

const { categorySlug } = Astro.props;
const category = getBlogCategory(categorySlug);
const posts = (await getCollection('blog'))
	.filter((post) => post.data.category === categorySlug)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const postUrl = (id: string) => `${base}/blog/${id}/`;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`${category.label} | ${SITE_TITLE}`} description={category.description} />
		<style>
			main {
				width: 960px;
			}
			.category-intro {
				margin-bottom: 2rem;
			}
			.category-intro p {
				margin: 0;
				color: rgb(var(--gray));
			}
			.post-list {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.post-list li {
				width: calc(50% - 1rem);
			}
			.post-list li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			.post-list li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			.post-list li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			.post-list li a:hover h2,
			.post-list li a:hover .date {
				color: rgb(var(--accent));
			}
			.post-list a:hover img {
				box-shadow: var(--box-shadow);
			}
			.empty {
				padding: 2rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				background: white;
				color: rgb(var(--gray));
			}
			@media (max-width: 720px) {
				.post-list {
					gap: 1rem;
				}
				.post-list li {
					width: 100%;
					text-align: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="category-intro">
				<h1>{category.label}</h1>
				<p>{category.description}</p>
			</section>
			<section>
				{
					posts.length === 0 ? (
						<p class="empty">아직 이 카테고리에 공개된 글이 없습니다.</p>
					) : (
						<ul class="post-list">
							{posts.map((post) => (
								<li>
									<a href={postUrl(post.id)}>
										{post.data.heroImage && (
											<Image width={720} height={360} src={post.data.heroImage} alt="" />
										)}
										<h2 class="title">{post.data.title}</h2>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							))}
						</ul>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
