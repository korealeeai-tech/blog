---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { type BlogCategorySlug, getBlogCategory } from '../categories';

type AdjacentPost = Pick<CollectionEntry<'blog'>, 'id' | 'data'>;
type Props = CollectionEntry<'blog'>['data'] & {
	category?: BlogCategorySlug;
	newerPost?: AdjacentPost;
	olderPost?: AdjacentPost;
};

const { title, description, pubDate, updatedDate, category, heroImage, newerPost, olderPost } =
	Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const postCategory = category ? getBlogCategory(category) : undefined;
const categoryUrl = postCategory ? `${base}/categories/${postCategory.slug}/` : '';
const postUrl = (id: string) => `${base}/blog/${id}/`;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				box-sizing: border-box;
				width: min(920px, calc(100% - 2em));
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.category {
				display: inline-block;
				margin-bottom: 0.75rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				padding: 0.2rem 0.7rem;
				background: white;
				color: rgb(var(--gray-dark));
				font-size: 0.85em;
				text-decoration: none;
			}
			.category:hover {
				border-color: rgb(var(--accent));
				color: rgb(var(--accent));
			}
			.last-updated-on {
				font-style: italic;
			}
			.post-navigation {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.post-navigation a {
				display: block;
				min-height: 7rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 1rem;
				background: white;
				color: rgb(var(--gray-dark));
				text-decoration: none;
			}
			.post-navigation a:hover {
				border-color: rgb(var(--accent));
				box-shadow: var(--box-shadow);
			}
			.post-navigation a:hover .nav-title {
				color: rgb(var(--accent));
			}
			.nav-label {
				display: block;
				margin-bottom: 0.5rem;
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			.nav-title {
				display: block;
				color: rgb(var(--black));
				font-size: 1rem;
				font-weight: 700;
				line-height: 1.4;
			}
			.next-link {
				text-align: right;
			}
			@media (max-width: 720px) {
				.post-navigation {
					grid-template-columns: 1fr;
				}
				.next-link {
					text-align: left;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										마지막 수정일: <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						{postCategory && <a class="category" href={categoryUrl}>{postCategory.label}</a>}
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
					{
						(olderPost || newerPost) && (
							<nav class="post-navigation" aria-label="이전 글과 다음 글">
								{olderPost ? (
									<a class="previous-link" href={postUrl(olderPost.id)}>
										<span class="nav-label">이전 글</span>
										<span class="nav-title">{olderPost.data.title}</span>
									</a>
								) : (
									<div></div>
								)}
								{newerPost ? (
									<a class="next-link" href={postUrl(newerPost.id)}>
										<span class="nav-label">다음 글</span>
										<span class="nav-title">{newerPost.data.title}</span>
									</a>
								) : (
									<div></div>
								)}
							</nav>
						)
					}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
